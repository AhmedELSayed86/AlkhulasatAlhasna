<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Alkhulasat.App.Views.SettingsPage"
    Style="{StaticResource StylePages}"
    Title="الإعدادات"
    FlowDirection="RightToLeft">
    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="20">
            <!-- قسم التفاعل (Haptic) -->
            <Label
                Text="تفضيلات الاستخدام"
                TextColor="#BB86FC"
                Margin="5,0" />
            <Border
                BackgroundColor="#1E1E1E"
                StrokeShape="RoundRectangle 15"
                Padding="15"
                Stroke="#333">
                <Grid
                    ColumnDefinitions="*, Auto">
                    <VerticalStackLayout
                        Grid.Column="0"
                        VerticalOptions="Center"
                        Spacing="2">
                        <Label
                            Text="ابقاء الشاشة تعمل"
                            TextColor="#E0E0E0"
                            FontSize="18" />
                        <Label
                            Text="ابقاء الشاشاة تعمل اثناء عمل البرنامج."
                            TextColor="#777"
                            FontSize="12" />
                    </VerticalStackLayout>
                    <!-- مفتاح التحكم -->
                    <Switch
                        x:Name="swScreenOn"
                        Grid.Column="1"
                        IsToggled="{Binding IsKeepScreenOn}"
                        OnColor="#03DAC6"
                        ThumbColor="#BB86FC" />
                </Grid>
            </Border>
            <Border
                BackgroundColor="#1E1E1E"
                StrokeShape="RoundRectangle 15"
                Padding="15"
                Stroke="#333">
                <Grid
                    ColumnDefinitions="*, Auto">
                    <VerticalStackLayout
                        Grid.Column="0"
                        VerticalOptions="Center"
                        Spacing="2">
                        <Label
                            Text="الاهتزاز عند التسبيح"
                            TextColor="#E0E0E0"
                            FontSize="18" />
                        <Label
                            Text="تفعيل اهتزاز بسيط عند النقر على الذكر، بعض الاجهزة غير مدعومة."
                            TextColor="#777"
                            FontSize="12" />
                    </VerticalStackLayout>
                    <!-- مفتاح التحكم -->
                    <Switch
                        x:Name="swHaptic"
                        Grid.Column="1"
                        IsToggled="{Binding IsHapticEnabled}"
                        OnColor="#03DAC6"
                        ThumbColor="#BB86FC" />
                </Grid>
            </Border>
            <Border
                BackgroundColor="#1E1E1E"
                StrokeShape="RoundRectangle 15"
                Padding="15"
                Stroke="#333"
                Margin="0,10,0,0">
                <Grid
                    ColumnDefinitions="*, Auto">
                    <VerticalStackLayout
                        Grid.Column="0"
                        VerticalOptions="Center">
                        <Label
                            Text="إذا كان الذَاكر امرأةٌ"
                            TextColor="#E0E0E0"
                            FontSize="18" />
                        <Label
                            Text="تبديل الكلمات (مثل: عبدك إلى أمتك)"
                            TextColor="#777"
                            FontSize="12" />
                    </VerticalStackLayout>
                    <Switch
                        x:Name="swFemale"
                        Grid.Column="1"
                        IsToggled="{Binding IsFemaleVersion}"
                        OnColor="#03DAC6"
                        ThumbColor="#BB86FC" />
                </Grid>
            </Border>
            <VerticalStackLayout
                Padding="10"
                Spacing="10">
                <Label
                    Text="حجم الخط"
                    FontSize="18"
                    TextColor="White"
                    HorizontalOptions="Center" />
                <Label
                    Text="{Binding FontSize, StringFormat='الحجم الحالي: {0:F0}'}"
                    TextColor="Gray"
                    HorizontalOptions="Center" />
                <Slider
                    Minimum="16"
                    Maximum="40"
                    Value="{Binding FontSize}"
                    MinimumTrackColor="#3B82F6"
                    ThumbColor="#3B82F6" />
                <!-- النص التجريبي: يجب أن يستخدم DynamicResource ليتغير مع السلايدر -->
                <Label
                    Text="« آللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ وَعَلَى آلِ مُحَمَّدٍ ، كَمَا صَلَّيْتَ عَلَى إِبْرَاهِيمَ وَعَلَى آلِ إِبْرَاهِيمَ ، إِنَّكَ حَمِيدٌ مَجِيدٌ . اللَّهُمَّ بَارِكْ عَلَى مُحَمَّدٍ وَعَلَى آلِ مُحَمَّدٍ ، كَمَا بَارَكْتَ عَلَى إِبْرَاهِيمَ وَعَلَى آلِ إِبْرَاهِيمَ ، إِنَّكَ حَمِيدٌ مَجِيدٌ »"
                    TextColor="#AAAAAA"
                    HorizontalOptions="Center"
                    Margin="0,20" />
            </VerticalStackLayout>
            <!-- إصدار التطبيق (للتوثيق) -->
            <VerticalStackLayout
                Spacing="5"
                Margin="0, 30, 0, 50"
                HorizontalOptions="Center">
                <Label
                    Text="{Binding AppVersionText}"
                    HorizontalOptions="Center"
                    TextColor="#444"
                    Margin="0,20" />
                <!-- إصدار قاعدة البيانات (للتوثيق) -->
                <Label
                    Text="{Binding DbVersionText}"
                    HorizontalOptions="Center"
                    TextColor="#444"
                    Margin="0,20" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
